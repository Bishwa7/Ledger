{
  "name": "Ledger",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate:signup": "dotenv -e apps/auth/signupBackend/.env -- pnpm --filter @repo/ledger-db run migrate",
    "db:generate:signup": "dotenv -e apps/auth/signupBackend/.env -- pnpm --filter @repo/ledger-db run generate"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
